---
const { title = "Mikey Higgs" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400;1,9..144,500&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet"/>
</head>
<body>
  <div class="wrapper">
    <nav>
      <div class="nav-inner">
        <a class="nav-brand" href="/">Mikey <em>Higgs</em></a>
        <ul class="nav-links">
          <li><a href="/projects">Projects</a></li>
          <li><a href="/writing">Writing</a></li>
          <li><a href="/videos">Videos</a></li>
        </ul>
      </div>
    </nav>
    <slot />
  </div>
</body>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --orange: #E8601C;
    --ink:    #1C1C1E;
    --muted:  #6B6B6B;
    --rule:   #E5E5E0;
    --bg:     #FAFAF8;
  }

  html { -webkit-font-smoothing: antialiased; }

  body {
    font-family: 'Atkinson Hyperlegible', sans-serif;
    background: var(--bg);
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.6;
  }

  a { color: var(--orange); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .wrapper {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  nav {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .nav-brand {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .nav-brand em {
    font-style: italic;
    color: var(--orange);
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover { color: var(--ink); }

  section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--rule);
  }

  section:last-of-type { border-bottom: none; }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  h2 em { font-style: italic; color: var(--orange); }

  .section-link {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .section-link:hover { color: var(--orange); }

  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--rule);
  }

  .hero-kicker {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hero-kicker::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1.5px;
    background: var(--orange);
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  h1 em {
    font-style: italic;
    color: var(--orange);
  }

  .hero-bio {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 1.75rem;
  }

  .hero-bio strong { color: var(--ink); font-weight: 700; }

  .hero-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
    border: none;
  }

  .btn-filled {
    background: var(--orange);
    color: white;
  }

  .btn-filled:hover {
    background: #cf551a;
    text-decoration: none;
  }

  .btn-outline {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--rule);
  }

  .btn-outline:hover {
    border-color: var(--ink);
    text-decoration: none;
  }

  .project-card {
    border: 1.5px solid var(--rule);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .project-card:hover {
    border-color: var(--orange);
    text-decoration: none;
  }

  .project-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .project-title {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .project-status {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .status-live { background: #E8F5ED; color: #2D9E4F; }
  .status-wip  { background: #FEF3EC; color: var(--orange); }

  .project-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .project-tag {
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: color 0.15s;
  }

  .post-item:first-child { padding-top: 0; }
  .post-item:last-child { border-bottom: none; padding-bottom: 0; }

  .post-item:hover .post-title { color: var(--orange); }

  .post-title {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--ink);
    transition: color 0.15s;
    line-height: 1.4;
  }

  .post-date {
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .yt-placeholder {
    border: 1.5px dashed var(--rule);
    border-radius: 8px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .yt-icon {
    font-size: 2rem;
    opacity: 0.4;
  }

  .yt-label {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--muted);
  }

  .yt-sub {
    font-size: 0.825rem;
    color: var(--muted);
    max-width: 320px;
    line-height: 1.6;
  }

  footer {
    padding: 2.5rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-name {
    font-family: 'Fraunces', serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: -0.01em;
  }

  .footer-name em { font-style: italic; color: var(--orange); }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover { color: var(--orange); }

  @media (max-width: 480px) {
    .nav-links { gap: 1.1rem; }
    h1 { font-size: 2.2rem; }
    .section-head { flex-direction: column; gap: 0.25rem; }
  }

  .post-content {
  padding: 2rem 0;
  font-size: 1rem;
  line-height: 1.8;
  color: var(--ink);
}

.post-content p {
  margin-bottom: 1.25rem;
}

.post-content h2, .post-content h3 {
  font-family: 'Fraunces', serif;
  font-weight: 500;
  letter-spacing: -0.02em;
  margin: 2rem 0 0.75rem;
}

.post-content strong { font-weight: 700; }
.post-content em { font-style: italic; }

.post-content a {
  color: var(--orange);
  text-decoration: underline;
}

.cards {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.card {
  border: 1.5px solid var(--rule);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  transition: border-color 0.15s;
  text-decoration: none;
  color: inherit;
}

.card:hover { border-color: var(--orange); }

.card-img {
  width: 140px;
  height: 110px;
  object-fit: cover;
  flex-shrink: 0;
}

.card-body {
  padding: 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.35rem;
}

.card-date {
  font-size: 0.72rem;
  color: var(--muted);
}

.card-title {
  font-family: 'Fraunces', serif;
  font-size: 1rem;
  font-weight: 500;
  letter-spacing: -0.01em;
  line-height: 1.3;
  color: var(--ink);
  transition: color 0.15s;
}

.card:hover .card-title { color: var(--orange); }

.card-excerpt {
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.5;
}


.post-hero-img {
  width: 100%;
  height: 280px;
  object-fit: cover;
  border-radius: 10px;
  margin-top: 2rem;
}
</style>
</html>