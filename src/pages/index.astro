---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = posts.slice(0, 3);

const videos = await getCollection('videos');
videos.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentVideos = videos.slice(0, 3);

---
<Layout>

<div class="hero">
  <p class="hero-bio">
    I'm an <strong>Information Officer in the NHS</strong> looking to train to teach secondary maths in September 2026. I am very interested in <strong>visualising maths</strong>.
  </p>
</div>

<section>
  <div class="section-head">
    <h2>Writing</h2>
    <a href="/writing" class="section-link">All posts →</a>
  </div>
  <div class="cards">
    {recentPosts.map((post: any) => (
      <a href={`/posts/${post.slug}`} class="card">
        {post.data.image && <img class="card-img" src={post.data.image} alt="" />}
        <div class="card-body">
          <div class="card-date">{post.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}</div>
          <div class="card-title">{post.data.title}</div>
          {post.data.excerpt && <div class="card-excerpt">{post.data.excerpt}</div>}
        </div>
      </a>
    ))}
  </div>
</section>

<section>
  <div class="section-head">
    <h2>Projects</h2>
    <a href="/projects" class="section-link">All projects →</a>
  </div>
  <a href="#" class="project-card">
    <div class="project-card-top">
      <div class="project-title">Sieve of Eratosthenes</div>
      <span class="project-status status-wip">Coming soon</span>
    </div>
    <div class="project-desc"></div>
    <div class="project-tag">Python · Number theory · KS3–4</div>
  </a>
</section>

<section>
	<div class="section-head">
    <h2>Videos</h2>
    <a href="/videos" class="section-link">All videos →</a>
  </div>
  <div class="cards">
  {recentVideos.map((v: any) => (
    <a href={v.data.url} class="card" target="_blank">
      {v.data.thumbnail && <img class="card-img-video" src={v.data.thumbnail} alt={v.data.title} />}
      <div class="card-body">
        <div class="card-date">{v.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}</div>
        <div class="card-title">{v.data.title}</div>
      </div>
    </a>
  ))}
</div>
</section>

<section>
  <div class="section-head">
    <h2>Teacher Tools</h2>
  </div>
  <a href="/timer" class="project-card">
    <div class="project-card-top">
      <div class="project-title">Classroom Timer</div>
    </div>
  </a>
</section>

</Layout>