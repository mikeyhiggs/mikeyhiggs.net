---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About | Mikey Higgs">
  <div class="hero" style="border-bottom: none;">
    <div class="hero-kicker">About me</div>
    <h1>Mikey<br/><em>Higgs</em></h1>
  </div>

  <section>
    <div class="section-head">
      <h2>Me</h2>
    </div>
    <p style="color: var(--muted); line-height: 1.75;">
      Write something about yourself here.
    </p>
  </section>

  <section>
    <div class="section-head">
      <h2>Equipment</h2>
    </div>
    <p style="color: var(--muted); line-height: 1.75;">
      Write about your setup here.
    </p>
  </section>
</Layout>