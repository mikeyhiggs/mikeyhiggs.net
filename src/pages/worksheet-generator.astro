---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Worksheet Generator | Mikey Higgs">
  <section>
    <div class="section-head">
      <h2>Worksheet Generator</h2>
    </div>

    <div class="ws-layout">

      <!-- ── CONTROLS ── -->
      <div class="controls">

        <div class="field">
          <label>Level</label>
          <select id="input-level">
            <option>GCSE Maths</option>
            <option>A Level Maths</option>
            <option>KS3 Maths</option>
            <option>Further Maths</option>
            <option>Primary Maths</option>
          </select>
        </div>

        <div class="field">
          <label>Topic</label>
          <input type="text" id="input-topic" placeholder="e.g. Integration by Parts"/>
        </div>

        <div class="field">
          <label>Question — wrap maths in $...$</label>
          <textarea id="input-question" rows="4" placeholder="e.g. Find $\displaystyle\int x e^x\,dx$"></textarea>
        </div>

        <div class="field">
          <div class="label-row">
            <label>Question size</label>
            <span class="label-value" id="qsize-value">56</span>
          </div>
          <input type="range" id="input-qsize" min="20" max="100" value="56"/>
        </div>

        <div class="field">
          <div class="label-row">
            <label>Dot grid rows</label>
            <span class="label-value" id="rows-value">20</span>
          </div>
          <input type="range" id="input-rows" min="3" max="20" value="20"/>
        </div>

        <div class="field">
          <div class="label-row">
            <label>Preview zoom</label>
            <span class="label-value" id="zoom-value">50%</span>
          </div>
          <input type="range" id="input-zoom" min="20" max="80" value="50"/>
        </div>

        <button class="dl-btn" id="dl-btn">⬇ Download PDF</button>

      </div>

      <!-- ── PREVIEW ── -->
      <div class="preview-wrap">
        <span class="preview-label">Preview</span>
        <div class="slide-outer" id="slide-outer">
        <div id="slide" class="slide">
          <div class="slide-bar"></div>
          <div class="slide-header">
            <span class="slide-level" id="slide-level">GCSE Maths</span>
            <span class="slide-url">mikeyhiggs.net</span>
          </div>
          <div class="slide-rule"></div>
          <div class="slide-pill" id="slide-pill">Topic</div>
          <div class="slide-question" id="slide-question"></div>
          <div class="slide-dots" id="slide-dots"></div>
        </div>
        </div>
        <p class="render-hint" id="render-hint" style="display:none;">Rendering maths…</p>
      </div>

    </div>
  </section>
</Layout>

<!-- Libraries -->
<script is:inline>
  window.MathJax = {
    startup: { typeset: false },
    tex: { inlineMath: [['$','$']], displayMath: [['$$','$$']] },
    svg: { fontCache: 'global' },
    options: { skipHtmlTags: ['script','noscript','style','textarea','pre'] }
  };
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style is:global>
  .ws-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* Controls */
  .controls {
    background: white;
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    border: 1.5px solid var(--rule);
  }
  .controls .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .controls label {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .label-row { display: flex; justify-content: space-between; align-items: center; }
  .label-value { font-family: 'DM Mono', monospace; font-size: 0.62rem; color: var(--orange); }
  .controls input[type="text"],
  .controls select,
  .controls textarea {
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 0.875rem;
    padding: 0.55rem 0.7rem;
    border: 1.5px solid var(--rule);
    border-radius: 6px;
    background: var(--bg);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    resize: vertical;
  }
  .controls input[type="text"]:focus,
  .controls select:focus,
  .controls textarea:focus { border-color: var(--orange); }
  .controls input[type="range"] { width: 100%; accent-color: var(--orange); cursor: pointer; }

  .dl-btn {
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.7rem 1rem;
    background: var(--orange);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
    width: 100%;
  }
  .dl-btn:hover { background: #cf551a; }
  .dl-btn:disabled { background: var(--muted); cursor: not-allowed; }

  /* Preview wrapper */
  .preview-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  .slide-outer {
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    /* width and height set by JS to match scaled size */
  }
  .preview-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .render-hint {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--orange);
    text-align: center;
    margin: 0;
  }

  /* ── THE SLIDE ── */
  /* Fixed pixel size for html2canvas consistency — scaled down with transform for preview */
  .slide {
    width: 1122px;
    height: 794px;
    background: #F5F5F0;
    position: relative;
    overflow: hidden;
    transform-origin: top left;
    font-family: 'Atkinson Hyperlegible', Georgia, sans-serif;
    flex-shrink: 0;
  }

  .slide-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 8px;
    background: #E8601C;
  }

  .slide-header {
    position: absolute;
    top: 16px; left: 32px; right: 32px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .slide-level {
    font-size: 28px;
    font-style: italic;
    color: #1C1C1E;
  }

  .slide-url {
    font-family: 'DM Mono', monospace;
    font-size: 24px;
    color: #6B6B6B;
  }

  .slide-rule {
    position: absolute;
    top: 80px; left: 32px; right: 32px;
    height: 1px;
    background: #DDDDD8;
  }

  .slide-pill {
    position: absolute;
    top: 94px; left: 32px;
    background: #E8601C;
    color: white;
    font-size: 26px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 4px;
    font-family: 'Atkinson Hyperlegible', sans-serif;
  }

  .slide-question {
    position: absolute;
    top: 144px; left: 32px; right: 32px;
    font-size: 56px;
    color: #1C1C1E;
    line-height: 1.3;
  }

  /* MathJax colour fix */
  .slide-question mjx-container, .slide-question svg { color: #1C1C1E !important; }

  .slide-dots {
    position: absolute;
    left: 32px; right: 32px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dot-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 28px;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #DDDDD8;
    flex-shrink: 0;
  }

  @media (max-width: 780px) { .ws-layout { grid-template-columns: 1fr; } }
</style>

<script is:inline>
(function() {
  if (window.__wsGenReady) return;
  window.__wsGenReady = true;

  var DOT_COLS = 36;
  var SLIDE_W = 1122;
  var SLIDE_H = 794;

  var state = {
    level: 'GCSE Maths',
    topic: '',
    question: '',
    rows: 20,
    qsize: 56,
  };

  function el(id) { return document.getElementById(id); }

  var zoom = 0.50;

  function scaleSlide() {
    var slide = el('slide');
    var outer = el('slide-outer');
    slide.style.transform = 'scale(' + zoom + ')';
    outer.style.width = Math.round(SLIDE_W * zoom) + 'px';
    outer.style.height = Math.round(SLIDE_H * zoom) + 'px';
  }

  function buildDots() {
    var container = el('slide-dots');
    container.innerHTML = '';
    container.style.top = '244px';
    container.style.bottom = '20px';

    // Calculate how many rows fit in the available space
    var ROW_H = 28;
    var available = SLIDE_H - 244 - 20;
    var maxRows = Math.floor(available / ROW_H);
    var rows = Math.min(state.rows, maxRows);

    for (var r = 0; r < rows; r++) {
      var row = document.createElement('div');
      row.className = 'dot-row';
      for (var c = 0; c < DOT_COLS; c++) {
        var dot = document.createElement('div');
        dot.className = 'dot';
        row.appendChild(dot);
      }
      container.appendChild(row);
    }
  }

  var qTimer;
  function updatePreview() {
    el('slide-level').textContent = state.level;
    el('slide-pill').textContent = state.topic || 'Topic';

    var qDiv = el('slide-question');
    qDiv.style.fontSize = state.qsize + 'px';
    qDiv.innerHTML = state.question || '';

    if (window.MathJax && MathJax.typesetPromise && state.question) {
      el('render-hint').style.display = 'block';
      MathJax.typesetClear([qDiv]);
      MathJax.typesetPromise([qDiv]).then(function() {
        el('render-hint').style.display = 'none';
      });
    }

    buildDots();
    scaleSlide();
  }

  // ── Inputs ────────────────────────────────────────────
  el('input-level').addEventListener('change', function() {
    state.level = this.value; updatePreview();
  });
  el('input-topic').addEventListener('input', function() {
    state.topic = this.value; updatePreview();
  });
  el('input-question').addEventListener('input', function() {
    state.question = this.value;
    clearTimeout(qTimer);
    qTimer = setTimeout(updatePreview, 400);
  });
  el('input-qsize').addEventListener('input', function() {
    state.qsize = +this.value;
    el('qsize-value').textContent = state.qsize;
    el('slide-question').style.fontSize = state.qsize + 'px';
  });

  el('input-rows').addEventListener('input', function() {
    state.rows = +this.value;
    el('rows-value').textContent = state.rows;
    buildDots();
  });

  window.addEventListener('resize', scaleSlide);

  el('input-zoom').addEventListener('input', function() {
    zoom = +this.value / 100;
    el('zoom-value').textContent = this.value + '%';
    scaleSlide();
  });

  // ── Download ──────────────────────────────────────────
  el('dl-btn').addEventListener('click', function() {
    var btn = el('dl-btn');
    btn.disabled = true;
    btn.textContent = 'Generating…';

    var slide = el('slide');

    // Temporarily remove transform so html2canvas captures at full resolution
    slide.style.transform = 'none';

    html2canvas(slide, {
      scale: 2,
      useCORS: true,
      backgroundColor: '#F5F5F0',
      width: SLIDE_W,
      height: SLIDE_H,
      logging: false,
    }).then(function(canvas) {
      // Restore scale
      scaleSlide();

      var imgData = canvas.toDataURL('image/png');
      var pdf = new window.jspdf.jsPDF({
        orientation: 'landscape',
        unit: 'mm',
        format: 'a4',
      });

      // A4 landscape: 297mm × 210mm
      pdf.addImage(imgData, 'PNG', 0, 0, 297, 210);

      var slug = (state.topic || 'worksheet').toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
      pdf.save(slug + '.pdf');

      btn.disabled = false;
      btn.textContent = '⬇ Download PDF';
    }).catch(function(err) {
      console.error(err);
      scaleSlide();
      btn.disabled = false;
      btn.textContent = '⬇ Download PDF';
    });
  });

  // ── Init ─────────────────────────────────────────────
  buildDots();
  scaleSlide();

  if (window.MathJax && MathJax.startup) {
    MathJax.startup.promise.then(updatePreview);
  } else {
    updatePreview();
  }
})();
</script>